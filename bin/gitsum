#!/usr/bin/env ruby

$LOAD_PATH.unshift(File.expand_path("../lib", __dir__))
require "gitsum"
require "json"
require "optparse"

opts = { dir: ".", format: "pretty", top: 10 }
OptionParser.new do |o|
  o.banner = "usage: gitsum [options] [dir]"
  o.on("--json", "machine-readable output") { opts[:format] = "json" }
  o.on("--top N", Integer, "show top N (default 10)") { |n| opts[:top] = n }
  o.on("-v", "--version") { puts "gitsum #{Gitsum::VERSION}"; exit }
  o.on("-h", "--help") { puts o; exit }
end.parse!(ARGV)

opts[:dir] = ARGV.shift if ARGV.any?

begin
  report = Gitsum.scan(opts[:dir])
rescue Gitsum::Error => e
  warn "gitsum: #{e.message}"
  exit 1
end

if opts[:format] == "json"
  puts JSON.pretty_generate(
    total_commits: report.total_commits,
    first_commit: report.first_commit,
    last_commit: report.last_commit,
    authors: report.authors,
    extensions: report.extensions,
  )
  exit 0
end

# pretty output
puts "repo:   #{File.expand_path(opts[:dir])}"
puts "span:   #{report.first_commit} → #{report.last_commit}"
puts "commits: #{report.total_commits}"
puts ""
puts "authors (top #{opts[:top]}):"
report.authors.first(opts[:top]).each do |name, count|
  pct = (count.to_f / report.total_commits * 100).round(1)
  bar_len = [(pct / 2).round, 1].max
  bar = "▇" * bar_len
  printf("  %-24s %5d  %5.1f%%  %s\n", name[0, 24], count, pct, bar)
end

puts ""
puts "lines by extension (top #{opts[:top]}):"
total_lines = report.extensions.values.sum
report.extensions.first(opts[:top]).each do |ext, lines|
  pct = total_lines.zero? ? 0 : (lines.to_f / total_lines * 100).round(1)
  printf("  %-10s %8d  %5.1f%%\n", ext, lines, pct)
end
